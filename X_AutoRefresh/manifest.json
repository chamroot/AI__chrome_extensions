{
  "manifest_version": 3,
  "name": "X Auto Refresh",
  "short_name": "XAR",
  "description": "X(Twitter)のタイムラインを自動更新します。その他機能についてはgithubで確認してください。",
  "version": "0.1.2",
  "author": "chamroot",
  "homepage_url": "https://github.com/chamroot/AI__chrome_extensions/tree/main/X_AutoRefresh",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "X Auto Refresh",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
